# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role Key (für Seed-Script und Public Form API)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Resend (E-Mail-Versand für Lead-Benachrichtigungen)
# Account erstellen: https://resend.com → Domain verifizieren → API Key generieren
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@deinefirma.de
FROM_NAME=Webseitenverlag Deutschland

# Stripe (Closing-Flow: Payment-Link → Auto-Provisioning)
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Webhook-Endpoint anlegen: https://dashboard.stripe.com/webhooks → Event: checkout.session.completed
# URL: https://deine-domain.de/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# Pipeline v2 — Datenbeschaffung (beide optional, sanfte Degradation)
# Firecrawl: besseres Website-Scraping (Fallback: eigener Scraper) — https://firecrawl.dev
# FIRECRAWL_API_KEY=fc-...
# Google Places: Adresse, Telefon, Öffnungszeiten, echte Bewertungen — https://console.cloud.google.com (Places API New)
# GOOGLE_PLACES_API_KEY=AIza...

# App-URL (für Links in E-Mails)
NEXT_PUBLIC_APP_URL=https://webseitenverlag-deutschland.vercel.app

# Lead-Benachrichtigungen von der Landing-Page (Fallback: FROM_EMAIL)
LEAD_NOTIFY_EMAIL=felix@deinefirma.de

# Host-Routing (optional — erst setzen, wenn Produktdomain steht)
# Marketing-Domain (Landing + /admin) und App-Domain (Kunden-Portal)
# NEXT_PUBLIC_MARKETING_HOST=webseitenverlag.de
# NEXT_PUBLIC_APP_HOST=app.webseitenverlag.de

# Optional: Standard-Cloudflare-Credentials (werden pro Kunde in der DB gespeichert)
# CLOUDFLARE_ACCOUNT_ID=your-account-id
# CLOUDFLARE_API_TOKEN=your-api-token
