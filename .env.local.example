# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role Key (für Seed-Script und Public Form API)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Resend (E-Mail-Versand für Lead-Benachrichtigungen)
# Account erstellen: https://resend.com → Domain verifizieren → API Key generieren
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@deinefirma.de
FROM_NAME=Webseitenverlag Deutschland

# App-URL (für Links in E-Mails)
NEXT_PUBLIC_APP_URL=https://webseitenverlag-deutschland.vercel.app

# Optional: Standard-Cloudflare-Credentials (werden pro Kunde in der DB gespeichert)
# CLOUDFLARE_ACCOUNT_ID=your-account-id
# CLOUDFLARE_API_TOKEN=your-api-token
